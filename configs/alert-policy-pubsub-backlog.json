              "resource.labels.subscription_id"
            ]
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 100,
        "duration": "120s",
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "notificationChannels": [
    "projects/serverless-ejguidon-dev/notificationChannels/17424193045619288052"
  ]
